---
// src/pages/heic-to-jpg.astro
import Base from "../layouts/Base.astro";
import { SITE_URL } from "../consts";

const PATH = "/heic-to-jpg";
const PAGE_URL = SITE_URL + PATH;

const faqs = [
  { q: "Is this HEIC to JPG converter free?", a: "Yes. It is completely free, with no sign-up, no watermark and no limit on how many photos you convert." },
  { q: "Are my photos private?", a: "Completely. HEIC files are converted entirely inside your browser and are never uploaded to any server. Your photos never leave your device." },
  { q: "What is a HEIC file?", a: "HEIC is the high-efficiency photo format iPhones use by default. It saves space but many apps and Windows PCs can't open it — converting to JPG fixes that." },
  { q: "Can I convert multiple HEIC files at once?", a: "Yes. Add as many HEIC photos as you like and convert them all to JPG in one go, then download them individually or all together." },
  { q: "How do I change HEIC to JPG on Windows?", a: "Just open this page in your browser on Windows, add your HEIC files and click Convert — no software to install. The JPGs download straight to your PC." },
  { q: "Does converting reduce photo quality?", a: "Conversion keeps your photos at full resolution with high JPG quality, so they look the same while becoming universally compatible." },
];

const steps = [
  { name: "Add your HEIC photos", text: "Drag and drop your .heic files into the box, or click “Choose files” to select them from your device." },
  { name: "Convert to JPG", text: "Click “Convert to JPG”. Each photo is decoded and converted right in your browser." },
  { name: "Download your JPGs", text: "Download each photo, or click “Download all” to save every JPG at once." },
];

const features = [
  { t: "Made for iPhone photos", d: "Decodes Apple's HEIC format and turns it into universal JPG." },
  { t: "100% private", d: "Photos are converted in your browser and never uploaded anywhere." },
  { t: "Batch convert", d: "Convert many HEIC files to JPG at once, then download them all." },
  { t: "Full resolution", d: "Your photos keep their original size and quality." },
  { t: "Free, no sign-up", d: "No account, no watermark, no limits, no software to install." },
  { t: "Works on Windows too", d: "Open HEIC photos that Windows can't, right in any browser." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebApplication", name: "HEIC to JPG Converter", url: PAGE_URL, applicationCategory: "UtilitiesApplication", operatingSystem: "Any (web-based)", description: "Free online tool to convert HEIC to JPG. Turn iPhone HEIC photos into universal JPG images, directly in your browser. No upload.", offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
    { "@type": "HowTo", name: "How to convert HEIC to JPG", step: steps.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.name, text: s.text })) },
    { "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
    { "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL }, { "@type": "ListItem", position: 2, name: "HEIC to JPG", item: PAGE_URL } ] },
  ],
};
---

<Base
  title="HEIC to JPG — Free Converter for iPhone Photos"
  description="Convert HEIC to JPG free. Turn iPhone HEIC photos into universal JPG images right in your browser. Batch convert, no upload, no sign-up, no watermark."
  path={PATH}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <section class="hero">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a> <span>/</span> <span>HEIC to JPG</span></nav>
    <h1>HEIC to JPG Converter</h1>
    <p class="sub">Convert iPhone HEIC photos to JPG — free, batch, and right in your browser. Nothing leaves your device.</p>
    <ul class="trust">
      <li>✓ Free, no sign-up</li>
      <li>✓ Batch convert</li>
      <li>✓ Works on Windows &amp; Mac</li>
      <li>🔒 Files never leave your device</li>
    </ul>

    <div class="card">
      <div id="dropzone" class="dropzone">
        <svg class="up" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M12 16V4m0 0L7 9m5-5 5 5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4 17v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2" stroke-linecap="round"/>
        </svg>
        <p class="dz-title">Drag &amp; drop your HEIC photos here</p>
        <p class="muted">.heic or .heif — or</p>
        <button id="pickBtn" type="button" class="btn-secondary">Choose files</button>
        <input id="fileInput" type="file" accept=".heic,.heif,image/heic,image/heif" multiple hidden />
      </div>
      <div id="bar" class="bar" hidden>
        <span id="count" class="count"></span>
        <button id="clearBtn" type="button" class="link">Clear all</button>
      </div>
      <div id="list" class="filelist"></div>
      <button id="convertBtn" type="button" class="btn-primary" hidden>Convert to JPG</button>
      <p id="status" class="status" aria-live="polite"></p>
      <div id="bar2" class="bar" hidden>
        <span class="count">Converted</span>
        <button id="downloadAll" type="button" class="btn-secondary">Download all</button>
      </div>
      <div id="results" class="thumbs"></div>
    </div>
  </section>

  <section class="features">
    {features.map((f) => (<div class="feature"><span class="dot" aria-hidden="true"></span><div><h3>{f.t}</h3><p>{f.d}</p></div></div>))}
  </section>

  <div class="ad-slot">Ad space</div>

  <section class="content">
    <h2>How to convert HEIC to JPG</h2>
    <ol class="steps">{steps.map((s) => (<li><strong>{s.name}.</strong> {s.text}</li>))}</ol>
  </section>

  <section class="content">
    <h2>Why convert HEIC to JPG?</h2>
    <p>iPhones save photos as HEIC to keep file sizes small, but the format isn't supported everywhere — Windows, older apps, and many websites still can't open a .heic file. Converting HEIC to JPG makes your photos work anywhere, while keeping full resolution. This converter changes your HEIC files to JPG right in your browser, so even private photos are never uploaded. You can convert one or batch-convert a whole camera roll at once.</p>
  </section>

  <section class="content">
    <h2>Frequently asked questions</h2>
    <div class="faqs">{faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </section>

  <script>
    import heic2any from "heic2any";

    const $ = (id) => document.getElementById(id);
    const dropzone = $("dropzone"), fileInput = $("fileInput"), listEl = $("list"), resultsEl = $("results");
    const convertBtn = $("convertBtn"), status = $("status"), bar = $("bar"), bar2 = $("bar2"), count = $("count");
    let files = [];      // input File objects
    let outputs = [];    // { name, url }

    $("pickBtn").addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", (e) => addFiles(e.target.files));
    $("clearBtn").addEventListener("click", () => { files = []; outputs = []; renderList(); resultsEl.innerHTML = ""; bar2.hidden = true; status.textContent = ""; });
    ["dragenter","dragover"].forEach((ev) => dropzone.addEventListener(ev, (e) => { e.preventDefault(); dropzone.classList.add("over"); }));
    ["dragleave","drop"].forEach((ev) => dropzone.addEventListener(ev, (e) => { e.preventDefault(); dropzone.classList.remove("over"); }));
    dropzone.addEventListener("drop", (e) => addFiles(e.dataTransfer.files));
    $("downloadAll").addEventListener("click", () => { outputs.forEach((o, i) => setTimeout(() => download(o), i * 250)); });

    function isHeic(f) { return /\.(heic|heif)$/i.test(f.name) || f.type === "image/heic" || f.type === "image/heif"; }

    function addFiles(fileList) {
      [...fileList].filter(isHeic).forEach((f) => files.push(f));
      renderList();
    }

    function renderList() {
      listEl.innerHTML = "";
      files.forEach((f, i) => {
        const row = document.createElement("div");
        row.className = "filerow";
        row.innerHTML = '<span class="fname">' + f.name + '</span><button class="remove" aria-label="Remove">×</button>';
        row.querySelector(".remove").addEventListener("click", () => { files.splice(i, 1); renderList(); });
        listEl.appendChild(row);
      });
      const has = files.length > 0;
      bar.hidden = !has; convertBtn.hidden = !has;
      count.textContent = files.length + (files.length === 1 ? " file" : " files") + " ready";
    }

    function download(o) {
      const a = document.createElement("a");
      a.href = o.url; a.download = o.name;
      document.body.appendChild(a); a.click(); a.remove();
    }

    convertBtn.addEventListener("click", async () => {
      if (!files.length) return;
      outputs = []; resultsEl.innerHTML = ""; bar2.hidden = true;
      convertBtn.disabled = true;
      for (let i = 0; i < files.length; i++) {
        status.textContent = "Converting… (" + (i + 1) + "/" + files.length + ")";
        try {
          const res = await heic2any({ blob: files[i], toType: "image/jpeg", quality: 0.92 });
          const blob = Array.isArray(res) ? res[0] : res;
          const url = URL.createObjectURL(blob);
          const name = files[i].name.replace(/\.(heic|heif)$/i, "") + ".jpg";
          const out = { name, url };
          outputs.push(out);
          addResult(out);
        } catch (err) {
          status.textContent = "One file could not be converted (it may not be a valid HEIC).";
        }
      }
      convertBtn.disabled = false;
      status.textContent = "✓ " + outputs.length + (outputs.length === 1 ? " photo" : " photos") + " converted";
      bar2.hidden = outputs.length === 0;
    });

    function addResult(o) {
      const card = document.createElement("div");
      card.className = "thumb";
      card.innerHTML = '<img src="' + o.url + '" alt="" /><button class="dl" title="Download JPG">↓</button>';
      card.querySelector(".dl").addEventListener("click", () => download(o));
      resultsEl.appendChild(card);
    }
  </script>

  <style>
    .card { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.5rem; text-align: left; }
    .dropzone { border: 2px dashed #d6cdf0; border-radius: 14px; padding: 2.4rem 1rem; text-align: center; transition: .18s; background: linear-gradient(#fff, #fdfcff); }
    .dropzone.over { border-color: var(--accent); background: var(--soft); transform: scale(1.005); }
    .dropzone .up { width: 42px; height: 42px; color: var(--accent); margin-bottom: .4rem; }
    .dz-title { font-weight: 700; font-size: 1.05rem; margin: 0; }
    .dropzone .muted { color: var(--muted); margin: .35rem 0 .8rem; font-size: .92rem; }
    .bar { display: flex; align-items: center; justify-content: space-between; margin: 1rem 0 .25rem; }
    .count { font-weight: 700; font-size: .9rem; }
    .link { background: none; border: none; color: var(--muted); cursor: pointer; font-size: .85rem; text-decoration: underline; }
    .filelist { margin: .5rem 0 1rem; }
    .filerow { display: flex; align-items: center; justify-content: space-between; padding: .5rem .7rem; border: 1px solid var(--line); border-radius: 9px; margin-bottom: .4rem; font-size: .9rem; }
    .filerow .fname { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .filerow .remove { border: none; background: none; color: var(--muted); font-size: 1.1rem; cursor: pointer; }
    .btn-primary { width: 100%; border: none; cursor: pointer; color: #fff; background: linear-gradient(135deg, var(--accent), var(--accent-2)); padding: .9rem 1.6rem; border-radius: 11px; font-size: 1.08rem; font-weight: 800; box-shadow: var(--shadow); }
    .btn-primary:disabled { opacity: .6; cursor: default; }
    .btn-secondary { background: #fff; border: 1px solid var(--accent); color: var(--accent); padding: .45rem 1rem; border-radius: 9px; font-weight: 700; cursor: pointer; font-size: .9rem; }
    .status { text-align: center; color: var(--muted); min-height: 1.3em; margin: .8rem 0 0; font-size: .92rem; }
    .thumbs { display: flex; flex-wrap: wrap; gap: .7rem; margin: .6rem 0; }
    .thumb { position: relative; width: 100px; height: 100px; border-radius: 11px; overflow: hidden; border: 1px solid var(--line); background: #fafafa; }
    .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .thumb .dl { position: absolute; right: 5px; bottom: 5px; width: 26px; height: 26px; border: none; border-radius: 8px; background: var(--accent); color: #fff; font-size: 1rem; line-height: 1; cursor: pointer; }
  </style>
</Base>
